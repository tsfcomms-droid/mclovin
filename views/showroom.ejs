<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Showroom - McLovin EU</title>
  <meta name="description" content="McLovin EU - showroom" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Permanent+Marker&family=Poppins:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<%
  const svgLeaf = `<svg class="icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>`;
  const svgHash = `<svg class="icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>`;
  const svgFlame = `<svg class="icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>`;
  const svgPhone = `<svg class="icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22z"/></svg>`;
  const svgBag = `<svg class="icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>`;
%>
<body class="public-page">
  <img class="decor decor-rainbow-top" src="/img/decor-rainbow.svg" alt="" />
  <img class="decor decor-rainbow-bottom" src="/img/decor-rainbow.svg" alt="" />
  <img class="decor decor-burst" src="/img/decor-burst.svg" alt="" />
  <img class="decor decor-splat" src="/img/decor-splat.svg" alt="" />
  <img class="decor-star" style="top: 14%; right: 8%;" src="/img/decor-star.svg" alt="" />
  <img class="decor-star" style="bottom: 22%; left: 6%; width: 16px;" src="/img/decor-star.svg" alt="" />

  <main class="page">
    <a class="back-link" href="/">&larr; back to links</a>

    <div class="brand">
      <% if (hasLogo) { %>
        <img id="site-logo" src="/img/logo.jpg" alt="McLovin EU logo" class="logo-img" style="max-width: 200px;" />
      <% } %>
    </div>

    <% if (settings.bannerEnabled && settings.bannerText) { %>
      <div class="announcement-banner"><%= settings.bannerText %></div>
    <% } %>

    <p class="tagline">the showroom <%- svgBag %></p>

    <% if (items.length === 0) { %>
      <p class="showroom-empty">Nothing in the showroom yet &mdash; check back soon.</p>
    <% } else { %>

      <div class="category-tabs">
        <button class="cat-tab tab-all active" data-filter="all">All</button>
        <button class="cat-tab tab-weed" data-filter="weed"><%- svgLeaf %> Weed</button>
        <button class="cat-tab tab-hash" data-filter="hash"><%- svgHash %> Hash</button>
      </div>

      <ul class="showroom-list" id="showroom-list">
        <% items.forEach(function(item) {
          var cat = item.category || 'weed';
          var activeTiers = (item.gramTiers || []).filter(function(t) { return t.grams || t.price; });
          var isWhatsApp = settings.orderUrl && settings.orderUrl.indexOf('wa.me') !== -1;
          var orderHref = settings.orderUrl
            ? (isWhatsApp
                ? settings.orderUrl + '?text=' + encodeURIComponent('Hi! I\'m interested in ' + item.title)
                : settings.orderUrl)
            : null;
        %>
          <li data-category="<%= cat %>">
            <div class="showroom-card<%= item.featured ? ' showroom-card--featured' : '' %>">
              <% if (item.featured) { %>
                <div class="featured-sticker"><%- svgFlame %> New drop</div>
              <% } %>
              <% if (!item.inStock) { %>
                <div class="sold-out-ribbon">Sold Out</div>
              <% } %>
              <% if (item.videoFilename) { %>
                <video class="showroom-video" src="/videos/<%= item.videoFilename %>" controls playsinline preload="metadata"></video>
              <% } else if (item.imageFilename) { %>
                <img class="showroom-photo" src="/images/<%= item.imageFilename %>" alt="<%= item.title %>" />
              <% } %>
              <div class="showroom-body">
                <div class="showroom-title-row">
                  <p class="showroom-title"><%= item.title %></p>
                  <span class="category-badge cat-<%= cat %>">
                    <%- cat === 'hash' ? svgHash : svgLeaf %> <%= cat === 'hash' ? 'Hash' : 'Weed' %>
                  </span>
                </div>
                <% if (item.description) { %>
                  <p class="showroom-desc"><%= item.description %></p>
                <% } %>
                <% if (activeTiers.length > 0) { %>
                  <div class="price-grid">
                    <% activeTiers.forEach(function(tier) { %>
                      <div class="price-chip">
                        <span class="price-grams"><%= tier.grams %></span>
                        <% if (tier.price) { %>
                          <span class="price-sep">→</span>
                          <span class="price-amount"><%= tier.price %> <span class="price-currency"><%= item.currency %></span></span>
                        <% } %>
                      </div>
                    <% }); %>
                  </div>
                <% } %>
              </div>
              <% if (orderHref && item.inStock) { %>
                <a href="<%= orderHref %>" class="showroom-card-order" target="_blank" rel="noopener noreferrer">
                  <%- svgPhone %> Order now
                </a>
              <% } %>
            </div>
          </li>
        <% }); %>
      </ul>
    <% } %>

    <footer class="footer">
      <p class="powered-by">Powered by <a href="https://t.me/+AFuV4h1EB19jZWM8" target="_blank" rel="noopener noreferrer">Premium Labs</a></p>
    </footer>
  </main>

  <script src="/js/logo-tap.js"></script>
  <script>
    var tabs = document.querySelectorAll('.cat-tab');
    var listItems = document.querySelectorAll('#showroom-list li');
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        tabs.forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');
        var filter = tab.dataset.filter;
        listItems.forEach(function(li) {
          li.style.display = (filter === 'all' || li.dataset.category === filter) ? '' : 'none';
        });
      });
    });
  </script>
</body>
</html>
