# Port the server listens on
PORT=3000

# Set NODE_ENV=production when running behind HTTPS (nginx/caddy reverse proxy)
NODE_ENV=production

# Optional: set a known admin password instead of using the auto-generated one.
# If set, this always overwrites the current admin password on every restart.
# Remove this line after first login if you'd rather manage the password
# from the admin dashboard's "Change password" form.
#ADMIN_PASSWORD=changeme123

# Long random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#SESSION_SECRET=
